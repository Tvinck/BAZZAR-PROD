{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/layout/**",
              "ui_kits/connect-mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|green|red|amber|violet)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'blue' | 'green' | 'red' | 'amber' | 'violet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|icon|block|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, icon, block, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|tonal|plain|blue)$/]",
        "message": "<Button> variant must be one of 'primary' | 'tonal' | 'plain' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|inset|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, inset, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:mine|author|authorColor|children|time|read|avatar|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: mine, author, authorColor, children, time, read, avatar."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|placeholder|type|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: value, defaultValue, onChange, placeholder, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|fill|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, fill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|color|bg|size|radius|iconSize|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: icon, color, bg, size, radius, iconSize."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconBg|iconColor|title|subtitle|onClick|right|chevron|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: icon, iconBg, iconColor, title, subtitle, onClick, right, chevron."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|large|onBack|onBell|bellDot|subtitle|right|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: title, large, onBack, onBell, bellDot, subtitle, right."
      },
      {
        "selector": "JSXOpeningElement[name.name='NotificationItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|date|time|title|text|icon|iconColor|key|ref|className|style|children)$/]",
        "message": "<NotificationItem> doesn't accept that prop. Declared props: category, date, time, title, text, icon, iconColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectPicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:projects|value|onChange|key|ref|className|style|children)$/]",
        "message": "<ProjectPicker> doesn't accept that prop. Declared props: projects, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromoBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|onDismiss|onClick|gradient|key|ref|className|style|children)$/]",
        "message": "<PromoBanner> doesn't accept that prop. Declared props: title, subtitle, icon, onDismiss, onClick, gradient."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconBg|iconColor|label|onClick|key|ref|className|style|children)$/]",
        "message": "<ServiceTile> doesn't accept that prop. Declared props: icon, iconBg, iconColor, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|tone|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, label, icon, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|green|red|amber)$/]",
        "message": "<StatCard> tone must be one of 'neutral' | 'blue' | 'green' | 'red' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|badge|key|ref|className|style|children)$/]",
        "message": "<TabBarItem> doesn't accept that prop. Declared props: key, label, icon, badge."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
